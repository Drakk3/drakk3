---
const skills = [
  { name: 'JavaScript', color: '#f7df1e', bg: '#1a1800', letter: 'JS' },
  { name: 'TypeScript', color: '#3178c6', bg: '#001428', letter: 'TS' },
  { name: 'React',      color: '#61dafb', bg: '#001219', letter: '⚛'  },
  { name: 'Next.js',    color: '#e0e0e0', bg: '#151515', letter: 'N'  },
  { name: 'Node.js',    color: '#68a063', bg: '#0b1a0b', letter: '⬡'  },
  { name: 'Python',     color: '#4584b6', bg: '#000e1f', letter: 'Py' },
  { name: 'PostgreSQL', color: '#336791', bg: '#000d1a', letter: '🐘' },
  { name: 'MongoDB',    color: '#47a248', bg: '#071507', letter: '🍃' },
  { name: 'Docker',     color: '#2496ed', bg: '#001223', letter: '🐳' },
  { name: 'Tailwind',   color: '#06b6d4', bg: '#001417', letter: '≋'  },
  { name: 'GraphQL',    color: '#e10098', bg: '#1a0010', letter: '◈'  },
  { name: 'Astro',      color: '#ff5d01', bg: '#1a0800', letter: '🚀' },
  { name: 'Git',        color: '#f05032', bg: '#1a0800', letter: '⎇'  },
  { name: 'Linux',      color: '#fcc624', bg: '#1a1400', letter: '🐧' },
];

const services = [
  {
    title: 'Web Development',
    items: ['React / Next.js SPAs', 'REST & GraphQL APIs', 'Performance optimization', 'Database design & queries'],
  },
  {
    title: 'Mobile Development',
    items: ['React Native cross-platform', 'iOS & Android deployment', 'Offline-first architecture', 'Push notifications'],
  },
  {
    title: 'UI/UX Design',
    items: ['Responsive design systems', 'Figma prototyping', 'Accessibility (WCAG 2.1)', 'Dark / light theming'],
  },
];
---

<section id="skills" class="py-24">
  <!-- Section header -->
  <div class="container max-w-[1100px] mx-auto px-6 mb-14">
    <p class="text-xs font-semibold tracking-[3px] uppercase text-primary mb-4">What I work with</p>
    <h2 class="text-[clamp(28px,4vw,42px)] font-bold leading-tight text-foreground">Skills &amp; Services</h2>
  </div>

  <!-- ── Infinite marquee ── -->
  <div
    class="overflow-hidden mb-18"
    style="mask-image:linear-gradient(to right,transparent,black 10%,black 90%,transparent);-webkit-mask-image:linear-gradient(to right,transparent,black 10%,black 90%,transparent);"
    aria-label="Technologies I use"
  >
    <div class="flex w-max gap-4 animate-marquee hover:[animation-play-state:paused] py-2">
      {[...skills, ...skills].map((skill) => (
        <!-- shadcn-style chip: border + bg-card + rounded-full -->
        <div class="flex items-center gap-2.5 bg-card border border-border rounded-full py-2 pl-2 pr-5 whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40 select-none cursor-default">
          <span
            class="w-8 h-8 rounded-full border flex items-center justify-center text-[13px] font-bold flex-shrink-0"
            style={`color:${skill.color};background:${skill.bg};border-color:${skill.color}22`}
          >
            {skill.letter}
          </span>
          <span class="text-[13px] font-medium text-muted-foreground">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Services — shadcn Cards ── -->
  <div class="container max-w-[1100px] mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group relative rounded-lg border border-border bg-card p-8 transition-all duration-250 hover:-translate-y-1 hover:border-primary/30 overflow-hidden">
          <!-- top accent bar on hover -->
          <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-primary/80 to-primary/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

          <h3 class="text-base font-bold text-foreground mb-5 pb-4 border-b border-border">
            {service.title}
          </h3>
          <ul class="space-y-3">
            {service.items.map((item) => (
              <li class="flex items-center gap-2.5 text-sm text-muted-foreground">
                <span class="text-primary text-[10px]">▸</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .mb-18 { margin-bottom: 4.5rem; }
</style>
