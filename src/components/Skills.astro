---
import { skills, technicalServices, operationalServices } from '@/data/skills';
---

<section id="skills" class="py-24">
  <!-- Section header -->
  <div class="container max-w-275 mx-auto px-6 mb-14">
    <p class="text-xs font-semibold tracking-[3px] uppercase text-muted-foreground mb-4">What I work with</p>
    <h2 class="text-[clamp(28px,4vw,42px)] font-bold leading-tight text-foreground">Skills &amp; Services</h2>
  </div>

  <!-- ── Infinite marquee ── -->
  <div
    class="overflow-hidden mb-18"
    style="mask-image:linear-gradient(to right,transparent,black 10%,black 90%,transparent);-webkit-mask-image:linear-gradient(to right,transparent,black 10%,black 90%,transparent);"
    aria-label="Technologies I use"
  >
    <div class="flex w-max gap-4 animate-marquee hover:[animation-play-state:paused] py-2">
      {[...skills, ...skills].map((skill) => (
        <div class="flex items-center gap-2.5 bg-card border border-zinc-800 rounded-full py-2 pl-2 pr-5 whitespace-nowrap transition-all duration-200 hover:-translate-y-0.5 hover:border-zinc-600 select-none cursor-default">
          <span
            class="w-8 h-8 rounded-full border flex items-center justify-center text-[13px] font-bold shrink-0"
            style={`color:${skill.color};background:${skill.bg};border-color:${skill.color}22`}
          >
            {skill.letter}
          </span>
          <span class="text-[13px] font-medium text-muted-foreground">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── Services — two columns ── -->
  <div class="container max-w-275 mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

      <!-- Technical column -->
      <div>
        <p class="text-xs font-semibold tracking-[3px] uppercase text-muted-foreground mb-5">Technical</p>
        <div class="flex flex-col gap-4">
          {technicalServices.map((service) => (
            <div class="group relative rounded-lg border border-zinc-800 bg-card p-6 transition-all duration-250 hover:-translate-y-1 hover:border-zinc-600 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-foreground/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <h3 class="text-base font-bold text-foreground mb-4 pb-3 border-b border-zinc-800">
                {service.title}
              </h3>
              <ul class="space-y-3">
                {service.items.map((item) => (
                  <li class="flex items-center gap-2.5 text-sm text-muted-foreground">
                    <span class="text-zinc-500 text-[10px]">▸</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- Operational & Leadership column -->
      <div>
        <p class="text-xs font-semibold tracking-[3px] uppercase text-muted-foreground mb-5">Operational &amp; Leadership</p>
        <div class="flex flex-col gap-4">
          {operationalServices.map((service) => (
            <div class="group relative rounded-lg border border-zinc-800 bg-card p-6 transition-all duration-250 hover:-translate-y-1 hover:border-zinc-600 overflow-hidden">
              <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-foreground/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <h3 class="text-base font-bold text-foreground mb-4 pb-3 border-b border-zinc-800">
                {service.title}
              </h3>
              <ul class="space-y-3">
                {service.items.map((item) => (
                  <li class="flex items-center gap-2.5 text-sm text-muted-foreground">
                    <span class="text-zinc-500 text-[10px]">▸</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .mb-18 { margin-bottom: 4.5rem; }
</style>
