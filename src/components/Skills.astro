---
const skills = [
  { name: 'JavaScript', color: '#f7df1e', bg: '#1a1800', letter: 'JS' },
  { name: 'TypeScript', color: '#3178c6', bg: '#001428', letter: 'TS' },
  { name: 'React', color: '#61dafb', bg: '#001219', letter: '⚛' },
  { name: 'Next.js', color: '#e0e0e0', bg: '#151515', letter: 'N' },
  { name: 'Node.js', color: '#68a063', bg: '#0b1a0b', letter: '⬡' },
  { name: 'Python', color: '#4584b6', bg: '#000e1f', letter: 'Py' },
  { name: 'PostgreSQL', color: '#336791', bg: '#000d1a', letter: '🐘' },
  { name: 'MongoDB', color: '#47a248', bg: '#071507', letter: '🍃' },
  { name: 'Docker', color: '#2496ed', bg: '#001223', letter: '🐳' },
  { name: 'Tailwind', color: '#06b6d4', bg: '#001417', letter: '≋' },
  { name: 'GraphQL', color: '#e10098', bg: '#1a0010', letter: '◈' },
  { name: 'Astro', color: '#ff5d01', bg: '#1a0800', letter: '🚀' },
  { name: 'Git', color: '#f05032', bg: '#1a0800', letter: '⎇' },
  { name: 'Linux', color: '#fcc624', bg: '#1a1400', letter: '🐧' },
];

const services = [
  {
    title: 'Web Development',
    icon: '◻',
    items: [
      'React / Next.js SPAs',
      'REST & GraphQL APIs',
      'Performance optimization',
      'Database design & queries',
    ],
  },
  {
    title: 'Mobile Development',
    icon: '◻',
    items: [
      'React Native cross-platform',
      'iOS & Android deployment',
      'Offline-first architecture',
      'Push notifications',
    ],
  },
  {
    title: 'UI/UX Design',
    icon: '◻',
    items: [
      'Responsive design systems',
      'Figma prototyping',
      'Accessibility (WCAG 2.1)',
      'Dark / light theming',
    ],
  },
];
---

<section id="skills" class="section">
  <div class="container skills-header">
    <p class="section-label">What I work with</p>
    <h2 class="section-title">Skills & Services</h2>
  </div>

  <!-- Infinite marquee -->
  <div class="marquee-wrapper" aria-label="Technologies I use">
    <div class="marquee-track">
      {[...skills, ...skills].map((skill) => (
        <div class="skill-chip">
          <span
            class="skill-icon"
            style={`color: ${skill.color}; background: ${skill.bg}; border-color: ${skill.color}22;`}
          >
            {skill.letter}
          </span>
          <span class="skill-name">{skill.name}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Services grid -->
  <div class="container">
    <div class="services-grid">
      {services.map((service) => (
        <div class="service-card">
          <h3 class="service-title">{service.title}</h3>
          <ul class="service-list">
            {service.items.map((item) => (
              <li class="service-item">
                <span class="check">▸</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .skills-header {
    margin-bottom: 56px;
  }

  /* ── Marquee ── */
  .marquee-wrapper {
    overflow: hidden;
    margin-bottom: 72px;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
  }

  .marquee-track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: marquee 30s linear infinite;
    padding: 8px 0;
  }

  .marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .skill-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 8px 18px 8px 8px;
    white-space: nowrap;
    transition: border-color 0.2s, transform 0.2s;
    user-select: none;
  }

  .skill-chip:hover {
    border-color: var(--border-accent);
    transform: translateY(-2px);
  }

  .skill-icon {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .skill-name {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-secondary);
  }

  /* ── Services ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    transition: border-color 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-dim), var(--accent));
    opacity: 0;
    transition: opacity 0.3s;
  }

  .service-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-4px);
  }

  .service-card:hover::before {
    opacity: 1;
  }

  .service-title {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }

  .service-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .service-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .check {
    color: var(--accent);
    font-size: 10px;
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
