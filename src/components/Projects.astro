---
import { projects } from '@/data/projects';
---

<section id="projects" class="py-24">
  <div class="container max-w-275 mx-auto px-6">
    <p class="text-xs font-semibold tracking-[3px] uppercase text-muted-foreground mb-4">What I've built</p>
    <h2 class="text-[clamp(28px,4vw,42px)] font-bold leading-tight text-foreground mb-3">Projects</h2>
    <p class="text-base text-muted-foreground max-w-120 leading-relaxed mb-10">
      A selection of work — software I've shipped and operations I've transformed.
    </p>

    <!-- Category filter -->
    <div class="flex gap-2 mb-10" id="project-filters" role="tablist" aria-label="Filter projects by category">
      {(['All', 'Tech', 'Operations'] as const).map((label) => (
        <button
          data-filter={label}
          role="tab"
          aria-selected={label === 'All' ? 'true' : 'false'}
          class:list={[
            'filter-btn h-9 px-5 rounded-md text-sm font-semibold border transition-all duration-200',
            label === 'All'
              ? 'border-zinc-500 bg-zinc-800 text-foreground'
              : 'border-zinc-800 bg-transparent text-muted-foreground hover:border-zinc-600 hover:text-foreground',
          ]}
        >
          {label}
        </button>
      ))}
    </div>

    <!-- Project grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12" id="projects-grid">
      {projects.map((project) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          data-category={project.category}
          class="project-card group flex flex-col rounded-lg border border-zinc-800 bg-card overflow-hidden"
        >
          <!-- Card header -->
          <div class="h-40 flex items-center justify-center relative" style={`background:${project.gradient}`}>
            <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/8 flex items-center justify-center backdrop-blur-sm">
              {project.category === 'Tech' ? (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="16 18 22 12 16 6"/>
                  <polyline points="8 6 2 12 8 18"/>
                </svg>
              ) : (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="3" width="5" height="5" rx="1"/>
                  <rect x="16" y="3" width="5" height="5" rx="1"/>
                  <rect x="9.5" y="16" width="5" height="5" rx="1"/>
                  <path d="M5.5 8v3a2 2 0 0 0 2 2h9a2 2 0 0 0 2-2V8"/>
                  <path d="M12 13v3"/>
                </svg>
              )}
            </div>
            <!-- Category pill -->
            <span class="absolute top-3 left-3 text-[10px] font-semibold tracking-wider uppercase px-2 py-0.5 rounded bg-zinc-900/70 text-zinc-400 border border-zinc-700">
              {project.category}
            </span>
          </div>

          <!-- Card body -->
          <div class="flex flex-col gap-3 p-6 flex-1">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-[16px] font-bold text-foreground leading-snug">{project.name}</h3>
              <span class="inline-flex items-center rounded-full border border-zinc-700 px-2.5 py-0.5 text-xs font-semibold whitespace-nowrap shrink-0 text-zinc-300">
                {project.status}
              </span>
            </div>

            <p class="text-[13.5px] text-muted-foreground leading-relaxed">{project.description}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mt-1">
              {project.tags.map(tag => (
                <span class="text-[11px] font-medium text-zinc-500 bg-zinc-900 border border-zinc-800 px-2.5 py-0.5 rounded">
                  {tag}
                </span>
              ))}
            </div>

            <span class="mt-auto text-[13px] font-medium text-muted-foreground group-hover:text-foreground transition-colors">
              View project →
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- GitHub CTA -->
    <div class="flex justify-center">
      <a
        href="https://github.com/drakk3"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2.5 h-10 px-8 rounded-md border border-zinc-800 bg-transparent text-sm font-semibold text-muted-foreground transition-all hover:border-zinc-600 hover:text-foreground hover:-translate-y-0.5"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        More on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .project-card {
    transition: opacity 0.2s ease, transform 0.2s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .project-card:hover {
    translate: 0 -6px;
    border-color: rgba(255, 255, 255, 0.12);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('#project-filters .filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.project-card');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      // Update active button state
      filterBtns.forEach((b) => {
        const active = b === btn;
        b.classList.toggle('border-zinc-500', active);
        b.classList.toggle('bg-zinc-800', active);
        b.classList.toggle('text-foreground', active);
        b.classList.toggle('border-zinc-800', !active);
        b.classList.toggle('text-muted-foreground', !active);
        b.setAttribute('aria-selected', String(active));
      });

      // Fade all cards out
      cards.forEach((card) => {
        card.style.opacity = '0';
        card.style.transform = 'scale(0.96)';
      });

      // After fade-out, toggle visibility then fade matching cards back in
      setTimeout(() => {
        cards.forEach((card) => {
          const match = filter === 'All' || card.dataset.category === filter;
          card.style.display = match ? '' : 'none';
        });

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            cards.forEach((card) => {
              if (card.style.display !== 'none') {
                card.style.opacity = '1';
                card.style.transform = '';
              }
            });
          });
        });
      }, 180);
    });
  });
</script>
