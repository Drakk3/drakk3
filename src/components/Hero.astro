---
---

<section id="hero" class="relative min-h-svh flex items-center overflow-hidden pt-16">
  <!-- Glow bg -->
  <div class="pointer-events-none absolute inset-0 z-0" aria-hidden="true">
    <div class="absolute -top-1/5 -right-1/10 w-150 h-150 rounded-full bg-primary/[0.07] blur-[80px]"></div>
  </div>

  <div class="container relative z-10 max-w-275 mx-auto px-6 py-20 grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
    <!-- Text -->
    <div>
      <p class="text-base text-muted-foreground mb-4 animate-[fade-up_0.6s_ease_both]">
        Hi, I'm <span class="text-primary font-semibold">Juan Valencia</span>
      </p>

      <h1 class="text-[clamp(52px,8vw,80px)] font-extrabold leading-[1.05] tracking-[-2px] text-foreground mb-6 animate-[fade-up_0.6s_0.1s_ease_both]">
        Tech<br />& Systems Engineer
      </h1>

      <p class="text-[17px] text-muted-foreground leading-[1.75] max-w-105 mb-10 animate-[fade-up_0.6s_0.2s_ease_both]">
        I write code and I run operations — two separate crafts, one way of thinking. Currently 70% through my Systems Engineering degree, building software and optimizing processes at Alo Distribution Center.
      </p>

      <div class="flex flex-wrap gap-4 animate-[fade-up_0.6s_0.3s_ease_both]">
        <!-- shadcn Button rendered as <a> via asChild pattern — using Astro we write the markup directly -->
        <a
          href="#projects"
          class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-semibold transition-all h-10 px-6 bg-primary text-primary-foreground hover:bg-primary/90 shadow hover:-translate-y-0.5 hover:shadow-[0_8px_24px_hsl(271,76%,61%,0.35)]"
        >
          View Projects
        </a>
        <a
          href="#contact"
          class="inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm font-semibold transition-all h-10 px-6 border border-border bg-transparent text-foreground hover:border-primary hover:text-primary hover:-translate-y-0.5"
        >
          Contact Me
        </a>
      </div>
    </div>

    <!-- Code decoration -->
    <div class="hidden md:block animate-[fade-up_0.6s_0.4s_ease_both]">
      <div class="relative rounded-lg border border-border bg-card p-7 font-mono text-[13.5px] leading-[1.8] text-muted-foreground overflow-hidden">
        <!-- top accent line -->
        <div class="absolute top-0 left-0 right-0 h-px bg-linear-to-r from-primary/60 to-transparent"></div>

        <span class="text-[#c084fc]">const </span>
        <span class="text-[#93c5fd]">dev</span>
        <span> = &#123;</span>
        <br />
        <span class="pl-6 block">
          <span class="text-[#f0abfc]">name</span>: <span class="text-[#86efac]">"drakk3"</span>,
        </span>
        <span class="pl-6 block">
          <span class="text-[#f0abfc]">role</span>: [<span class="text-[#86efac]">"Software Developer"</span>, <span class="text-[#86efac]">"Operations Analyst"</span>, <span class="text-[#86efac]">"Team Lead"</span>],
        </span>
        <span class="pl-6 block">
          <span class="text-[#f0abfc]">focus</span>: [<span class="text-[#86efac]">"Web"</span>, <span class="text-[#86efac]">"Mobile"</span>, <span class="text-[#86efac]">"Systems Thinking"</span>],
        </span>
        <span class="pl-6 block">
          <span class="text-[#f0abfc]">available</span>: <span class="text-[#fb923c]">true</span>,
        </span>
        <span>&#125;</span>
      </div>
    </div>
  </div>
</section>
